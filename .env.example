# ASP.NET Core Environment
# Valid values: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Production

# API Configuration
API_PORT=8080

# Database Configuration
# Connection string for SQLite database
# The path /app/data will be a mounted volume on EC2
ConnectionStrings__DefaultConnection=Data Source=/app/data/hng_stage_one.db

# Logging Configuration
# Valid values: Verbose, Debug, Information, Warning, Error, Fatal
LOG_LEVEL=Information

# CORS Configuration (if restricting origins in production)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Public URLs
Auth__BackendPublicUrl=http://localhost:8080
Auth__WebPortalUrl=http://localhost:5173

# GitHub OAuth App
# Callback URL in GitHub should be: http://localhost:8080/api/v1/auth/github/callback
GitHub__ClientId=your_github_oauth_client_id
GitHub__ClientSecret=your_github_oauth_client_secret

# JWT / Session Configuration
# Use a long random secret in production, at least 32 characters.
Jwt__Issuer=insighta-labs
Jwt__Audience=insighta-labs-clients
Jwt__SigningKey=replace_with_a_long_random_secret_at_least_32_chars
Jwt__AccessTokenMinutes=3
Jwt__RefreshTokenMinutes=5

# Comma-separated GitHub usernames that should receive admin role at login.
Auth__AdminGitHubUsernames=your-github-username

# Auth flow timing
Auth__OAuthSessionMinutes=10

# Rate limiting
RateLimit__AuthPermitLimit=10
RateLimit__ApiPermitLimit=60
RateLimit__WindowMinutes=1

# External demographic APIs
ExternalApis__GenderizeBaseUrl=https://api.genderize.io
ExternalApis__AgifyBaseUrl=https://api.agify.io
ExternalApis__NationalizeBaseUrl=https://api.nationalize.io

# External APIs (if credentials required in future)
# GENDERIZE_API_KEY=your_key_here
# AGIFY_API_KEY=your_key_here
# NATIONALIZE_API_KEY=your_key_here

# Docker-specific variables
# WAIT_FOR_DB_TIMEOUT=30 (seconds to wait for database)
